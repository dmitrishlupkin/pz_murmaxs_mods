<transitions>
    <transition>
        <transitionTo>hitreaction</transitionTo>
        <conditions>
            <isTrue>hashitreaction</isTrue>
        </conditions>
    </transition>
    <transition>
        <transitionTo>falldown</transitionTo>
        <conditions>
            <isTrue>bDead</isTrue>
            <isFalse>bOnFloor</isFalse>
        </conditions>
    </transition>
    <transition>
        <transitionTo>onground</transitionTo>
        <conditions>
            <isTrue>bDead</isTrue>
            <isTrue>bOnFloor</isTrue>
        </conditions>
    </transition>
    <transition>
        <transitionTo>eating</transitionTo>
        <conditions>
            <isTrue>isAnimalEating</isTrue>
        </conditions>
    </transition>
    <transition>
        <transitionTo>walk</transitionTo>
        <conditions>
            <isTrue>bMoving</isTrue>
            <isFalse>bPathfind</isFalse>
        </conditions>
    </transition>
    <transition>
        <transitionTo>pathfind</transitionTo>
        <conditions>
            <isTrue>bPathfind</isTrue>
        </conditions>
    </transition>

    <transition>
        <transitionTo>trailer</transitionTo>
        <conditions>
            <compare op="!=" a="TrailerAnimation" b="" />
        </conditions>
    </transition>
</transitions>
