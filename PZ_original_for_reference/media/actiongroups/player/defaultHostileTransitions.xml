<transitions>
    <transition>
        <transitionTo>melee</transitionTo>
        <asSubstate>false</asSubstate>
        <conditions>
            <isTrue>initiateAttack</isTrue>
            <isFalse>rangedWeapon</isFalse>
            <notEquals a="Weapon" b=""/>
            <isFalse>bDoShove</isFalse>
        </conditions>
    </transition>

    <transition>
        <transitionTo>shove</transitionTo>
        <asSubstate>false</asSubstate>
        <conditions>
            <isTrue>initiateAttack</isTrue>
            <isTrue>bDoShove</isTrue>
        </conditions>
    </transition>

    <transition>
        <transitionTo>ranged</transitionTo>
        <asSubstate>false</asSubstate>
        <conditions>
            <isTrue>initiateAttack</isTrue>
            <isTrue>rangedWeapon</isTrue>
            <isFalse>bDoShove</isFalse>
        </conditions>
    </transition>

    <!-- Attempting to Grab for a Grapple -->
    <transition>
        <transitionTo>grapple</transitionTo>
        <asSubstate>false</asSubstate>
        <conditions>
            <isTrue>initiateAttack</isTrue>
            <isTrue>bDoGrapple</isTrue>
        </conditions>
    </transition>

    <!-- Already Grappling -->
    <transition>
        <transitionTo>grapple</transitionTo>
        <asSubstate>false</asSubstate>
        <conditions>
            <isTrue>bIsGrappling</isTrue>
        </conditions>
    </transition>
</transitions>